{
  "name": "whatbreaks-monorepo",
  "version": "1.0.0",
  "description": "AI-powered pre-mortem engine for cloud infrastructure",
  "private": true,
  "workspaces": [
    "frontend",
    "backend/premortem-lambda"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend/premortem-lambda",
    "clean": "rm -rf frontend/node_modules frontend/.next backend/premortem-lambda/node_modules backend/*.zip",
    "deploy:infra": "cd infrastructure && ./deploy.sh",
    "deploy:infra:windows": "cd infrastructure && .\\deploy.ps1"
  },
  "keywords": [
    "aws",
    "ai",
    "premortem",
    "reliability",
    "infrastructure",
    "bedrock"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/whatbreaks"
  }
}
