# Cost Optimizer Collaborator
resource "aws_bedrockagent_agent_collaborator" "cost_collaborator" {
  agent_id                   = aws_bedrockagent_agent.supervisor.agent_id
  agent_version              = "DRAFT"
  collaborator_name          = "CostOptimizer"
